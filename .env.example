# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://srh_user:srh_pass@db:5432/srh_db

# ─── Admin ────────────────────────────────────────────────
# Bearer token required by /api/v1/admin/* endpoints.
ADMIN_API_KEY=change-me-in-production

# ─── App ──────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated allowed frontend origins. Set to the deployed SRH-FRONTEND
# origin in production (do NOT use "*" — invalid with credentials).
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# ─── Privacy ──────────────────────────────────────────────
# When false, raw text of UNSAFE queries is discarded (only the label/flag is
# stored). Set true only for explicit safety-audit needs.
LOG_UNSAFE_TEXT=false

# ─── Trained classifiers (Models 1–3) ─────────────────────
# Bare sklearn Pipelines (joblib) copied from the srh-ml-model repo into ./models.
# Loaded once at startup; if a file is absent the classifier falls back safely.
SAFETY_MODEL_PATH=models/safety_classifier.pkl
TOPIC_MODEL_PATH=models/topic_classifier_B.pkl
LANGUAGE_MODEL_PATH=models/language_classifier.pkl

# ─── Embeddings ───────────────────────────────────────────
# Multilingual sentence-transformer, 384-dim (handles Kinyarwanda via
# cross-lingual transfer). Loaded locally by default.
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
# Where embeddings run: auto (local, else HF API) | hf_api | local.
# Use hf_api on memory-limited hosts (e.g. Render free 512 MB) so torch/
# sentence-transformers are never loaded — loading them there OOMs and 502s /chat.
EMBEDDING_BACKEND=auto
# HuggingFace token — REQUIRED for LLM generation (chat_completion) and for
# EMBEDDING_BACKEND=hf_api. Optional only when running fully local.
HF_API_TOKEN=

# ─── Vector store ─────────────────────────────────────────
# "pinecone" (cloud) or "chroma" (local dev / CI — no API key needed).
VECTOR_STORE_BACKEND=pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=srh-knowledge-base
# Modern serverless spec (cloud + region). PINECONE_ENVIRONMENT is legacy only.
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_ENVIRONMENT=
CHROMA_PERSIST_DIR=./data/chroma_db

# ─── LLM ──────────────────────────────────────────────────
# HuggingFace model ID for response generation (set after the Part 5 benchmark).
LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
DEFAULT_LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
LLM_MAX_NEW_TOKENS=300
LLM_TIMEOUT_SECONDS=30
# Optional — GPT-4o reference benchmark only.
OPENAI_API_KEY=

# ─── Kinyarwanda embedder (English path above is UNCHANGED) ─
# rw retrieval uses bge-m3 (1024-dim) in its own Pinecone index.
RW_EMBEDDING_MODEL=BAAI/bge-m3
RW_EMBEDDING_DIM=1024
RW_PINECONE_INDEX_NAME=srh-knowledge-base-rw

# ─── Kinyarwanda answer pipeline (does NOT affect English) ─
# How rw queries are answered after the FAQ cache:
#   native    — bge-m3 retrieval + direct rw generation (default; no change).
#   translate — rw→en→(English RAG+gen)→en→rw; needs a TRANSLATION_PROVIDER.
KINYARWANDA_PIPELINE_MODE=native
# Predefined-question FAQ cache (built by scripts/build_faq_cache.py).
FAQ_CACHE_ENABLED=true
FAQ_SIMILARITY_THRESHOLD=0.90
FAQ_CACHE_PATH=data/faq_cache_rw.jsonl
# Translation provider (used only when KINYARWANDA_PIPELINE_MODE=translate).
TRANSLATION_PROVIDER=google
TRANSLATION_TIMEOUT_SECONDS=10
BACK_TRANSLATION_SIMILARITY_THRESHOLD=0.75
GOOGLE_TRANSLATE_API_KEY=
NLLB_ENDPOINT_URL=            # hosted NLLB-200 (CC-BY-NC 4.0 — non-commercial)
DIGITAL_UMUGANDA_MODEL_ID=
